BOT_TOKEN=123456:ABC-from-BotFather
# Railway: добавь PostgreSQL и вставь переменную DATABASE_URL из панели
DATABASE_URL=postgresql://user:pass@host:5432/dbname

# Необязательно
DEFAULT_TZ=Europe/Moscow
REMINDER_POLL_SECONDS=5
MIN_SPAM_INTERVAL_SECONDS=15
READ_ACK_INTERVAL_SECONDS=30

# Mini App: публичный HTTPS URL корня (тот же домен, что у сервиса Railway с ботом)
# WEBAPP_PUBLIC_URL=https://worker-production-xxxx.up.railway.app
# HTTP поднимается вместе с ботом на PORT. Только бот: MINIAPP_HTTP=0
# UVICORN_LOG_LEVEL=warning
